#!/usr/bin/env sh
# vim:ft=sh:et:ts=4:sw=4:sts=4:
#
# Translate text using any OpenAI-compatible API.
#
# Usage:
#   trans [options] [text...]
#   echo "hello" | trans -
#   trans --to zh "hello world"
#   trans --stream "hello world"
#
# Environment:
#   TRANSLATE_API_BASE  API base URL
#   TRANSLATE_API_KEY   API key
#   TRANSLATE_MODEL     Model name
#   TRANSLATE_TO        Default target language
#   TRANSLATE_PAIR      Default language pair

set -eu

usage() {
    cat <<EOF
Usage: $(basename "$0") [options] [text...]

Translate text using any OpenAI-compatible API.

Options:
    -b, --base URL     API base URL         (default: \$TRANSLATE_API_BASE, e.g. https://api.deepseek.com)
    -k, --key KEY      API key              (default: \$TRANSLATE_API_KEY,  e.g. \$DEEPSEEK_API_KEY)
    -m, --model NAME   Model name           (default: \$TRANSLATE_MODEL,    e.g. deepseek-chat)
    -t, --to LANG      Target language      (default: \$TRANSLATE_TO,       e.g. Chinese)
    -p, --pair LANGS   Language pair        (default: \$TRANSLATE_PAIR,     e.g. English:Chinese)
    -s, --stream       Stream the response
    -                  Read text from stdin
    -h, --help         Show this help message and exit
EOF
}

die() {
    printf '%s\n' "$*" >&2
    exit 1
}

# $@: args from command line
parse_args() {
    api_base="${TRANSLATE_API_BASE:-}"
    api_key="${TRANSLATE_API_KEY:-}"
    model="${TRANSLATE_MODEL:-}"
    target_lang="${TRANSLATE_TO:-}"

    pair="${TRANSLATE_PAIR:-}"
    stream=0
    use_stdin=0

    while [ $# -gt 0 ]; do
        case "$1" in
            -t | --to)
                target_lang="$2"
                shift 2
                ;;
            -m | --model)
                model="$2"
                shift 2
                ;;
            -k | --key)
                api_key="$2"
                shift 2
                ;;
            -b | --base)
                api_base="$2"
                shift 2
                ;;
            -p | --pair)
                pair="$2"
                shift 2
                ;;
            -s | --stream)
                stream=1
                shift
                ;;
            -h | --help)
                usage
                exit 0
                ;;
            --)
                shift
                break
                ;;
            -)
                use_stdin=1
                shift
                ;;
            -*)
                usage >&2
                exit 1
                ;;
            *)
                break
                ;;
        esac
    done

    if [ -z "$api_base" ]; then die "No API base URL set. Use -b or set TRANSLATE_API_BASE."; fi
    if [ -z "$api_key" ]; then die "No API key found, set TRANSLATE_API_KEY."; fi
    if [ -z "$model" ]; then die "No model set. Use -m or set TRANSLATE_MODEL."; fi
    if [ -z "$pair" ] && [ -z "$target_lang" ]; then
        die "No target language set. Use -t or set TRANSLATE_TO, or use -p for a language pair."
    fi

    if [ -n "$pair" ]; then
        pair_lang1="${pair%%:*}"
        pair_lang2="${pair##*:}"
        if [ -z "$pair_lang1" ] || [ -z "$pair_lang2" ] || [ "$pair_lang1" = "$pair_lang2" ]; then
            die "Invalid language pair '$pair'. Use format: LANG1:LANG2 (e.g. English:Chinese)"
        fi
    fi

    if [ "$use_stdin" -eq 1 ]; then
        text=$(cat)
    elif [ $# -gt 0 ]; then
        text="$*"
    else
        die "No text provided. Pass as arguments or use - to read from stdin."
    fi
    text=$(printf '%s' "$text" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')

    if [ -z "$text" ]; then
        die "Empty input."
    fi
}

build_system_prompt() {
    if [ -n "$pair" ]; then
        printf '%s' "You are a translator. If the text is mainly in $pair_lang1, translate to $pair_lang2. If it's mainly in $pair_lang2, translate to $pair_lang1. Output only the translation, nothing else."
    else
        printf '%s' "You are a translator. Translate the following text to $target_lang. Output only the translation, nothing else."
    fi
}

# $1: system prompt
call_api() {
    payload=$(jq -nc \
        --arg model "$model" \
        --arg system "$1" \
        --arg text "$text" \
        '{
            model: $model,
            messages: [
                {role: "system", content: $system},
                {role: "user",   content: $text}
            ],
            temperature: 0.3
        }')

    if ! response=$(curl -sS --fail-with-body \
        "$api_base/chat/completions" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $api_key" \
        -d "$payload"); then
        die "API request failed: $response"
    fi

    translation=$(printf '%s' "$response" | jq -r '.choices[0].message.content // empty')
    if [ -z "$translation" ]; then
        error=$(printf '%s' "$response" | jq -r '.error.message // empty')
        die "Translation failed: ${error:-unknown error}"
    fi
    printf '%s\n' "$translation"
}

# $1: system prompt
call_api_stream() {
    payload=$(jq -nc \
        --arg model "$model" \
        --arg system "$1" \
        --arg text "$text" \
        '{
            model: $model,
            messages: [
                {role: "system", content: $system},
                {role: "user",   content: $text}
            ],
            temperature: 0.3,
            stream: true
        }')

    curl -sSN \
        "$api_base/chat/completions" \
        -H "Content-Type: application/json" \
        -H "Authorization: Bearer $api_key" \
        -d "$payload" \
        --no-buffer | while IFS= read -r line; do
            case "$line" in
                "data: [DONE]" | "data:[DONE]") break ;;
                data:\ \{* | data:\{*)
                    printf '%s' "$line" | sed 's/^data:[[:space:]]*//' | jq -rj '.choices[0].delta.content // empty' 2>/dev/null
                    ;;
        esac
    done
    printf '\n'
}

main() {
    parse_args "$@"
    if [ "$stream" -eq 1 ]; then
        call_api_stream "$(build_system_prompt)"
    else
        call_api "$(build_system_prompt)"
    fi
}

main "$@"
